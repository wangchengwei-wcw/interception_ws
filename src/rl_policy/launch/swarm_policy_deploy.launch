<launch>
  <!--
    Policy deployment only.
    The enemy target generator is intentionally not started here because it
    spawns one target formation and drives it toward the origin. In real
    deployment there is no Isaac Lab-style environment reset, so start targets
    explicitly when needed:

      roslaunch rl_policy spawn_targets.launch
  -->
  <arg name="params_file" default="$(find rl_policy)/config/deployment_params_2.yaml"/>

  <rosparam command="load" file="$(arg params_file)"/>

  <group>
    <node pkg="rl_policy" type="swarm_state_manager.py" name="swarm_state_manager" output="screen"/>
    <!-- <node pkg="rl_policy" type="policy_control_node.py" name="policy_control_node" output="screen"/> -->
    <!-- <node pkg="rl_policy" type="policy_cmd_bridge.py" name="policy_cmd_bridge" output="screen"/> -->
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find rl_policy)/launch/rviz.rviz" output="screen"/>
  </group>
</launch>